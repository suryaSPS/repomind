# Copy this to .env.local and fill in your values

# ── Database ──────────────────────────────────────────────────────────────────
# Local (Docker):  postgresql://postgres:postgres@localhost:5432/repomind
# Neon (Vercel):   postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/repomind?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/repomind

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-a-random-32-char-string
# Local dev — on Vercel this is set automatically via the dashboard
NEXTAUTH_URL=http://localhost:3000

# Users to seed on first run — format: username:password,username2:password2
SEED_USERS=admin:changeme,alice:changeme2

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Register at: https://github.com/settings/developers → "New OAuth App"
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Register at: https://console.cloud.google.com → APIs & Services → Credentials
# Callback URL: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Twitter / X OAuth ─────────────────────────────────────────────────────────
# Register at: https://developer.twitter.com/en/portal/projects-and-apps
# App type: "Web App" — enable OAuth 2.0 with PKCE
# Callback URL: http://localhost:3000/api/auth/callback/twitter
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ── OpenAI — embeddings (text-embedding-3-small) ─────────────────────────────
OPENAI_API_KEY=sk-...

# ── Anthropic — Claude 3.7 Sonnet agent ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
