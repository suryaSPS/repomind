# Copy this to .env.local and fill in your values

# ── Database ──────────────────────────────────────────────────────────────────
# Local (Docker):  postgresql://postgres:postgres@localhost:5432/repomind
# Neon (Vercel):   postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/repomind?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/repomind

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-a-random-32-char-string
# Local dev — on Vercel this is set automatically via the dashboard
NEXTAUTH_URL=http://localhost:3000

# Users to seed on first run — format: username:password,username2:password2
SEED_USERS=admin:changeme,alice:changeme2

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Create at: https://github.com/settings/developers → OAuth Apps → New OAuth App
#
# App settings:
#   Homepage URL:              https://your-app.vercel.app
#   Authorization callback URL: https://your-app.vercel.app/api/auth/callback/github
#
# Scopes requested (set in lib/auth.ts): read:user user:email repo
#   The "repo" scope is required for private repository access.
#   For public repos only you can use: read:user user:email
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
#
# Authorized redirect URIs:
#   https://your-app.vercel.app/api/auth/callback/google
#   http://localhost:3000/api/auth/callback/google   (for local dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GitHub App Token (optional) ───────────────────────────────────────────────
# A personal access token or GitHub App token used as a fallback for public
# repos when no user OAuth token is available (e.g. unauthenticated ingest).
# Not required if all users sign in via GitHub OAuth.
GITHUB_TOKEN=

# ── OpenAI — embeddings (text-embedding-3-small) ─────────────────────────────
OPENAI_API_KEY=sk-...

# ── Anthropic — Claude Haiku agent ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
