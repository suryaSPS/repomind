# Required: Anthropic API key for Claude AI scenario generation
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override allowed CORS origins (default: http://localhost:3000)
CORS_ORIGINS=["http://localhost:3000"]

# Optional: backend port (default: 8000)
PORT=8000

# Frontend: backend URL (used at build time for Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
